{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "log/log-.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "NeonConnection": "need_to_be_not_empty",
    "NeonConnectionUnitTests": "need_to_be_not_empty"
  },
  "Auth0": {
    "Domain": "domain",
    "ClientId": "client"
  },
  "LocalStorage": {
    "RootPath": "/tmp"
  },
  "Cloudinary": {
    "CloudName": "cloudname",
    "ApiKey": "apikey",
    "ApiSecret": "apisecret",
    "Folder": "folder"
  },
  "GoogleBooks": {
    "BaseUrl": "https://www.googleapis.com/books/v1"
  },
  "Bedetheque": {
    "BaseUrl": "https://www.bedetheque.com",
    "SerpApiBaseUrl": "https://serpapi.com",
    "SerpApiKey": ""
  },
  "Import": {
    "ImportDirectory": "/data/import",
    "TempDirectory": "/data/temp",
    "ImageTargetWidth": 1400,
    "PollingIntervalSeconds": 30,
    "SupportedExtensions": [ ".cbz", ".cbr", ".zip", ".rar", ".pdf" ],
    "MaxFileSizeMb": 1024
  }
}


