@inherits LayoutComponentBase

<style>
    /* On mobile, push content above the fixed bottom nav bar */
    @@media (max-width: 959.95px) {
        .mud-main-content {
            padding-bottom: calc(72px + env(safe-area-inset-bottom)) !important;
        }
    }
</style>

<MudThemeProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudDialogProvider FullWidth="true"
                   MaxWidth="MaxWidth.ExtraExtraLarge"
                   CloseButton="true"
                   BackdropClick="false"
                   NoHeader="false"
                   Position="DialogPosition.Center"
                   CloseOnEscapeKey="true"
                   
                    />

<MudLayout>
    <NavBar />
    <MudMainContent>
        @Body
    </MudMainContent>    
</MudLayout>
