@using Domain.Libraries
@using Web.Enums

@rendermode InteractiveServer

@page "/libraries/list"

<PageWithAction Title="Libraries"
                Icon="@Icons.Material.Filled.CollectionsBookmark"
                ActionName="New library"
                ActionIcon="@Icons.Material.Filled.Add"
                OnActionClick="@(e => CreateOrEditAsync(FormMode.Create, null))">

    <MudGrid Spacing="4" Justify="Justify.FlexStart">
        @foreach (var lib in Libraries)
        {
            <MudItem @key="lib.Id" xs="12" sm="6" md="3">
                <MudCard Outlined="true"
                         Style="@($"border-left: 4px solid {lib.Color}; height: 100%;")">
                    <MudCardHeader>
                        <CardHeaderAvatar>
                            <MudIcon Icon="@IconPicker.Resolve(lib.Icon)"
                                     Style="@($"color: {lib.Color};")"
                                     Size="Size.Medium" />
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@lib.Name</MudText>
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Variant="Variant.Outlined"
                                     Style="@($"border-color: {lib.Color}; color: {lib.Color};")">
                                @lib.BookType.ToString()
                            </MudChip>
                            @if (lib.IsDefault)
                            {
                                <MudChip T="string" Size="Size.Small"
                                         Color="Color.Primary" Class="ml-1">Default</MudChip>
                            }
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                                     AriaLabel="Actions">
                                <MudMenuItem Label="Edit"
                                             OnClick="@(e => CreateOrEditAsync(FormMode.Edit, lib))" />
                                @if (!lib.IsDefault)
                                {
                                    <MudMenuItem Label="Delete"
                                                 OnClick="@(e => OnClickDeleteAsync(lib.Id))" />
                                }
                            </MudMenu>
                        </CardHeaderActions>
                    </MudCardHeader>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
</PageWithAction>
