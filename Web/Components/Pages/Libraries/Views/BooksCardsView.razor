@using Web.Components.SharedComponents

<div>
<MudGrid Spacing="4">
    @foreach (var book in Books)
    {
        <MudItem @key="book.Id" xs="12" sm="6" md="4" lg="3">
            <MudPaper Class="book-card" Elevation="2" @onclick="@(() => NavigateToBook(book.Id))">
                <div class="book-card-image-container">
                    @if (!string.IsNullOrEmpty(book.ImageLink))
                    {
                        <MudImage Src="@book.ImageLink" Alt="@book.Title" Class="book-card-image" />
                    }
                    else
                    {
                        <div class="book-card-image-placeholder">
                            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Large" Style="color: white; opacity: 0.7;" />
                        </div>
                    }
                </div>

                <div class="book-card-content">
                    <div class="d-flex justify-space-between align-start">
                        <div class="flex-grow-1 pr-2" style="min-width: 0;">
                            <div class="d-flex align-center gap-1" style="min-width: 0;">
                                <MudText Typo="Typo.subtitle2" Class="font-weight-bold book-card-title">@book.Title</MudText>
                                @if (book.VolumeNumber > 0)
                                {
                                    <span class="book-card-volume-badge">#@book.VolumeNumber</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(book.Serie))
                            {
                                <MudText Typo="Typo.caption" Class="book-card-serie">@book.Serie</MudText>
                            }
                        </div>
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" @onclick:stopPropagation="true" AriaLabel="More actions">
                            <MudMenuItem Icon="@Icons.Material.Filled.CloudDownload" Href="@($"/books/{book.Id}/import")">Import from Web</MudMenuItem>
                            @if (ShowDownload)
                            {
                                <MudMenuItem Icon="@Icons.Material.Filled.Download" IconColor="Color.Secondary" OnClick="@(() => OnDownload.InvokeAsync(book.Id))">Download CBZ</MudMenuItem>
                            }
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" Href="@($"/books/{book.Id}/edit")">Edit</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" OnClick="@(e => OnDelete.InvokeAsync(book.Id))">Delete</MudMenuItem>
                        </MudMenu>
                    </div>

                    <div class="d-flex flex-column gap-1 mt-1 flex-grow-1">
                        @if (!string.IsNullOrEmpty(book.Authors))
                        {
                            <div class="d-flex align-center gap-1">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="book-card-meta-icon" />
                                <MudText Typo="Typo.caption" Class="book-card-meta-text">@book.Authors</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(book.Publishers))
                        {
                            <div class="d-flex align-center gap-1">
                                <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" Class="book-card-meta-icon" />
                                <MudText Typo="Typo.caption" Class="book-card-meta-text">@book.Publishers</MudText>
                            </div>
                        }
                    </div>

                    <div class="d-flex align-center justify-space-between mt-auto pt-2">
                        <div class="d-flex align-center gap-2">
                            @if (!string.IsNullOrEmpty(book.ISBN))
                            {
                                <MudTooltip Text="@book.ISBN" Placement="Placement.Top">
                                    <MudIcon Icon="@Icons.Material.Filled.QrCode" Size="Size.Small" Class="book-card-meta-icon" />
                                </MudTooltip>
                            }
                            @if (book.LastRating.HasValue)
                            {
                                <MudRating SelectedValue="@book.LastRating.Value" MaxValue="5" Disabled="true" Size="Size.Small" />
                            }
                        </div>
                        @if (book.ReadCount > 0)
                        {
                            <div class="d-flex align-center gap-1">
                                <MudIcon Icon="@Icons.Material.Filled.BookmarkAdded" Size="Size.Small" Class="book-card-meta-icon" />
                                <MudText Typo="Typo.caption" Class="book-card-meta-text">@(book.ReadCount == 1 ? "Read" : $"Read {book.ReadCount}\u00d7")</MudText>
                            </div>
                        }
                    </div>
                </div>
            </MudPaper>
        </MudItem>
    }
</MudGrid>
</div>
