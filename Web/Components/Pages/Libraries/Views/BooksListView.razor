@using Web.Components.SharedComponents

<MudPaper Elevation="0">
    <MudTable @ref="_table" ServerData="ServerData" Hover="true" Breakpoint="Breakpoint.Xs" Dense="true" Striped="true" Class="rounded-lg">
        <HeaderContent>
            <MudTh>Series</MudTh>
            <MudTh Style="text-align: center;">Vol.</MudTh>
            <MudTh>Title</MudTh>
            <MudTh Style="text-align: center;">Last Read</MudTh>
            <MudTh Style="text-align: center;">Last Rating</MudTh>
            <MudTh>ISBN</MudTh>
            <MudTh Style="text-align: right;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Series">
                <MudText Typo="Typo.body2" Color="Color.Primary">@context.Serie</MudText>
            </MudTd>
            <MudTd DataLabel="Volume" Style="text-align: center;">
                @if (context.VolumeNumber > 0)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">@context.VolumeNumber</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Title">
                <MudText Typo="Typo.body2" Class="font-weight-medium">@context.Title</MudText>
            </MudTd>
            <MudTd DataLabel="Last Read" Style="text-align: center;">
                @if (context.LastRead.HasValue)
                {
                    <MudText Typo="Typo.caption">@context.LastRead.Value.ToString("d")</MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">-</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Last Rating" Style="text-align: center;">
                @if (context.LastRating > 0)
                {
                    <MudRating SelectedValue="@context.LastRating" MaxValue="5" Disabled="true" Size="Size.Small" />
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">-</MudText>
                }
            </MudTd>
            <MudTd DataLabel="ISBN">
                <MudText Typo="Typo.caption" Style="font-family: monospace;">@context.ISBN</MudText>
            </MudTd>
            <MudTd DataLabel="Actions" Style="text-align: right;" Class="list-actions-cell">
                <div class="action-buttons">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Default" Href="@($"/books/{context.Id}")" aria-label="View book" />
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" Href="@($"/books/{context.Id}/edit")" aria-label="Edit book" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(e => OnDelete.InvokeAsync(context.Id))" aria-label="Delete book" />
                </div>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">No books found.</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">Loading…</MudText>
        </LoadingContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 25, 50, 100 }" />
        </PagerContent>
    </MudTable>
</MudPaper>
