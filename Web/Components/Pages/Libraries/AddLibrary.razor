@rendermode InteractiveServer

@page "/libraries/add"

@using Domain.Libraries
@using Web.Components.SharedComponents
@using Web.Validators

<PageTitle>New Library — MyComicsManager</PageTitle>

<div class="add-library-page">
    @* Header *@
    <div class="add-library-header">
        <div class="d-flex align-center gap-3">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                           Color="Color.Inherit"
                           OnClick="GoBack" />
            <div>
                <MudText Typo="Typo.h6" Class="font-weight-bold" Style="color: white;">
                    New Library
                </MudText>
                <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.8);">
                    Fill in the details for your new library
                </MudText>
            </div>
        </div>
    </div>

    @* Content *@
    <div class="add-library-content">
        <MudPaper Class="pa-6 rounded-lg" Elevation="2">
            <MudForm Model="@_model" @ref="@_form"
                     Validation="@(_validator.ValidateValue)"
                     ValidationDelay="0">
                <MudStack Spacing="3">

                    @* Name *@
                    <MudTextField @bind-Value="_model.Name"
                                  For="@(() => _model.Name)"
                                  Immediate="true"
                                  Label="Library Name"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.LibraryBooks" />

                    @* Book type *@
                    <MudSelect T="LibraryBookType"
                               @bind-Value="_model.BookType"
                               For="@(() => _model.BookType)"
                               Label="Library Type"
                               Variant="Variant.Outlined"
                               Adornment="Adornment.Start"
                               AdornmentIcon="@Icons.Material.Filled.Category">
                        <MudSelectItem Value="LibraryBookType.Physical">Physical books</MudSelectItem>
                        <MudSelectItem Value="LibraryBookType.Digital">Digital books (eBooks)</MudSelectItem>
                    </MudSelect>

                    @* Color picker *@
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Color</MudText>
                    <div class="color-palette">
                        @foreach (var hex in ColorPalette)
                        {
                            <button type="button" class="color-swatch @(_model.Color == hex ? "selected" : "")" style="background-color: @hex"
                                    @onclick="@(() => _model.Color = hex)" aria-label="@($"Select color {hex}")" aria-pressed="@(_model.Color == hex)">
                                @if (_model.Color == hex)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Check"
                                             Size="Size.Small"
                                             Style="color: white;" />
                                }
                            </button>
                        }
                    </div>

                    @* Icon picker *@
                    <IconPicker @bind-Value="_model.Icon" Label="Icon" />

                    @* Live preview *@
                    <MudPaper Class="pa-3" Style="@($"border-left: 4px solid {_model.Color};")" Outlined="true">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@IconPicker.Resolve(_model.Icon)"
                                     Style="@($"color: {_model.Color};")"
                                     Size="Size.Medium" />
                            <MudText Typo="Typo.subtitle1">
                                @(string.IsNullOrEmpty(_model.Name) ? "Library preview" : _model.Name)
                            </MudText>
                        </MudStack>
                    </MudPaper>

                </MudStack>
            </MudForm>

            <div class="d-flex justify-end gap-2 mt-6">
                <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="GoBack">Cancel</MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="SaveAsync"
                           Disabled="_isSaving">
                    @if (_isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <text>Creating…</text>
                    }
                    else
                    {
                        <text>Create Library</text>
                    }
                </MudButton>
            </div>
        </MudPaper>
    </div>
</div>
