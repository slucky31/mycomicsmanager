@rendermode InteractiveServer

@page "/libraries/{LibraryId}"

@using Domain.Books
@using Domain.Libraries
@using Web.Components.SharedComponents
@using Web.Enums
@using Web.Validators

<PageTitle>@(_library?.Name ?? "Library") — MyComicsManager</PageTitle>

<div class="library-detail-page">
    @if (_isLoading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="d-flex mx-auto mt-8" />
    }
    else
    {
        @* Library header *@
        <PageHeader Title="@(_library?.Name ?? "")"
                    LibraryColor="@_library?.Color"
                    OnBack="GoBack">
            <Actions>
                @* Desktop: view toggle buttons *@
                <MudButtonGroup OverrideStyles="false" Class="mr-2 d-none d-sm-flex">
                    <MudTooltip Text="Card View">
                        <MudIconButton Icon="@Icons.Material.Filled.ViewModule"
                                       Color="@(_currentViewMode == ViewMode.Cards ? Color.Primary : Color.Default)"
                                       Variant="@(_currentViewMode == ViewMode.Cards ? Variant.Filled : Variant.Outlined)"
                                       OnClick="@(() => _currentViewMode = ViewMode.Cards)"
                                       Class="view-toggle-btn" />
                    </MudTooltip>
                    <MudTooltip Text="Cover View">
                        <MudIconButton Icon="@Icons.Material.Filled.GridView"
                                       Color="@(_currentViewMode == ViewMode.Covers ? Color.Primary : Color.Default)"
                                       Variant="@(_currentViewMode == ViewMode.Covers ? Variant.Filled : Variant.Outlined)"
                                       OnClick="@(() => _currentViewMode = ViewMode.Covers)"
                                       Class="view-toggle-btn" />
                    </MudTooltip>
                    <MudTooltip Text="List View">
                        <MudIconButton Icon="@Icons.Material.Filled.ViewList"
                                       Color="@(_currentViewMode == ViewMode.List ? Color.Primary : Color.Default)"
                                       Variant="@(_currentViewMode == ViewMode.List ? Variant.Filled : Variant.Outlined)"
                                       OnClick="@(() => _currentViewMode = ViewMode.List)"
                                       Class="view-toggle-btn" />
                    </MudTooltip>
                </MudButtonGroup>

                @* Desktop: sort buttons *@
                <MudButtonGroup OverrideStyles="false" Class="mr-2 d-none d-sm-flex">
                    <MudTooltip Text="Sort: newest first">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward"
                                       Color="@(_currentSortOrder == BookSortOrder.IdDesc ? Color.Primary : Color.Default)"
                                       Variant="@(_currentSortOrder == BookSortOrder.IdDesc ? Variant.Filled : Variant.Outlined)"
                                       OnClick="@(() => SetSortOrderAsync(BookSortOrder.IdDesc))"
                                       Class="view-toggle-btn" />
                    </MudTooltip>
                    <MudTooltip Text="Sort: oldest first">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward"
                                       Color="@(_currentSortOrder == BookSortOrder.IdAsc ? Color.Primary : Color.Default)"
                                       Variant="@(_currentSortOrder == BookSortOrder.IdAsc ? Variant.Filled : Variant.Outlined)"
                                       OnClick="@(() => SetSortOrderAsync(BookSortOrder.IdAsc))"
                                       Class="view-toggle-btn" />
                    </MudTooltip>
                    <MudTooltip Text="Sort: series &amp; volume">
                        <MudIconButton Icon="@Icons.Material.Filled.SortByAlpha"
                                       Color="@(_currentSortOrder == BookSortOrder.SerieAndVolumeAsc ? Color.Primary : Color.Default)"
                                       Variant="@(_currentSortOrder == BookSortOrder.SerieAndVolumeAsc ? Variant.Filled : Variant.Outlined)"
                                       OnClick="@(() => SetSortOrderAsync(BookSortOrder.SerieAndVolumeAsc))"
                                       Class="view-toggle-btn" />
                    </MudTooltip>
                </MudButtonGroup>

                <MudButton StartIcon="@Icons.Material.Filled.Add"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="AddBook"
                           Class="d-none d-sm-flex">
                    New Book
                </MudButton>

                @* Mobile: 3-dots menu with view + sort options *@
                <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                         Color="Color.Inherit"
                         Dense="true"
                         Class="d-flex d-sm-none">
                    <MudText Typo="Typo.overline" Class="px-4 pt-2 mud-text-secondary">View</MudText>
                    <MudMenuItem Icon="@Icons.Material.Filled.ViewModule"
                                 IconColor="@(_currentViewMode == ViewMode.Cards ? Color.Primary : Color.Default)"
                                 OnClick="@(() => _currentViewMode = ViewMode.Cards)">Cards</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.GridView"
                                 IconColor="@(_currentViewMode == ViewMode.Covers ? Color.Primary : Color.Default)"
                                 OnClick="@(() => _currentViewMode = ViewMode.Covers)">Covers</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.ViewList"
                                 IconColor="@(_currentViewMode == ViewMode.List ? Color.Primary : Color.Default)"
                                 OnClick="@(() => _currentViewMode = ViewMode.List)">List</MudMenuItem>
                    <MudDivider Class="my-1" />
                    <MudText Typo="Typo.overline" Class="px-4 mud-text-secondary">Sort</MudText>
                    <MudMenuItem Icon="@Icons.Material.Filled.ArrowDownward"
                                 IconColor="@(_currentSortOrder == BookSortOrder.IdDesc ? Color.Primary : Color.Default)"
                                 OnClick="@(() => SetSortOrderAsync(BookSortOrder.IdDesc))">Newest first</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.ArrowUpward"
                                 IconColor="@(_currentSortOrder == BookSortOrder.IdAsc ? Color.Primary : Color.Default)"
                                 OnClick="@(() => SetSortOrderAsync(BookSortOrder.IdAsc))">Oldest first</MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.SortByAlpha"
                                 IconColor="@(_currentSortOrder == BookSortOrder.SerieAndVolumeAsc ? Color.Primary : Color.Default)"
                                 OnClick="@(() => SetSortOrderAsync(BookSortOrder.SerieAndVolumeAsc))">Series &amp; volume</MudMenuItem>
                </MudMenu>
            </Actions>
        </PageHeader>

        @* Search bar — sticky with header *@
        <div class="library-search-wrapper">
            <MudTextField @bind-Value="_searchTerm"
                          Placeholder="Search by title or series…"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Clearable="true"
                          Immediate="true"
                          Variant="Variant.Outlined" />
        </div>
        <div class="library-detail-content">

            @* Books display *@
            @if (_books.Count == 0)
            {
                <MudPaper Class="pa-8 d-flex flex-column align-center justify-center" Style="min-height: 400px;" Elevation="0">
                    <MudIcon Icon="@IconPicker.Resolve(_library?.Icon)"
                             Style="@($"color: {_library?.Color}; font-size: 80px; opacity: 0.4;")" />
                    <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-4">No books in this library yet</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">Start by adding your first book</MudText>
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" OnClick="AddBook">
                        Add Your First Book
                    </MudButton>
                </MudPaper>
            }
            else if (_filteredBooks.Count == 0)
            {
                <MudPaper Class="pa-8 d-flex flex-column align-center justify-center" Style="min-height: 300px;" Elevation="0">
                    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" Style="font-size: 64px; opacity: 0.5;" />
                    <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-4">No results for "@_searchTerm"</MudText>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Class="mt-2" OnClick="@(() => _searchTerm = string.Empty)">
                        Clear search
                    </MudButton>
                </MudPaper>
            }
            else
            {
                @switch (_currentViewMode)
                {
                    case ViewMode.Cards:
                        <BooksCardsView Books="@_filteredBooks" OnDelete="@DeleteAsync" />
                        break;
                    case ViewMode.Covers:
                        <BooksCoversView Books="@_filteredBooks" OnDelete="@DeleteAsync" />
                        break;
                    case ViewMode.List:
                        <BooksListView Books="@_filteredBooks" OnDelete="@DeleteAsync" />
                        break;
                }
            }
        </div>
    }
</div>

@* FAB — outside page div to ensure viewport positioning *@
@if (!_isLoading)
{
    <div class="fab-add-book d-sm-none">
        <MudFab Color="Color.Primary"
                StartIcon="@Icons.Material.Filled.Add"
                OnClick="AddBook" />
    </div>
}
