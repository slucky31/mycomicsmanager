@using Tewr.Blazor.FileReader
@using System.Diagnostics
@using MyComicsManagerWeb.Models
@using MyComicsManagerWeb.Services
@using System.IO

@inject ComicService ComicService;
@inject IFileReaderService fileReaderService;

<div class="drag-drop-zone">

    <input type="file"
           class="clickable"
           @ref=selectedFile
           @onchange="ReadFile" />
    <div class="file-row">
        <!-- File info -->
        <div>

            @if (fileInfo != null)
            {

                <h2>@fileInfo.Name</h2>
                <p>Size: <strong>@fileInfo.Size bytes</strong></p>
                <p>Status: <strong>@status</strong></p>
                @*
                    @if (fileInfo.Size > MaxFileSize)
                    {
                    <p>That's too big. Max size: @(MaxFileSize) bytes.</p>;
                    }
                    else if (fileInfo.Data.Position == fileInfo.Size)
                    {
                    <p>Download finished !</p>
                    }
                    else
                    {
                    <p>Loaded @((100.0 * selectedFile.Data.Position / selectedFile.Size).ToString("0"))%</p>
                    }
                *@
            }
            else
            {
                <p>Déposer un fichier ou cliquer pour sélectionner un fichier</p>
            }
        </div>
    </div>

</div>

@code {

    [Parameter]
    public Comic comic { get; set; }

    ElementReference selectedFile { get; set; }
    String status { get; set; }

    private IFileInfo fileInfo;

    public async Task ReadFile()
    {

        var files = await fileReaderService.CreateReference(selectedFile).EnumerateFilesAsync();
        var file = files.First();

        fileInfo = await file.ReadFileInfoAsync();
        status = $"Reading file...";
        this.StateHasChanged();

        Stopwatch stopWatch = new Stopwatch();
        stopWatch.Start();

        await ComicService.UploadFile(file, fileInfo.Name);
        //var filePath = Path.Combine("/lib/tmp/", fileInfo.Name);
        //using (var fileStream = new FileStream(filePath, FileMode.Create))
        //using (var fs = await file.OpenReadAsync())
        //{
        //    await fs.CopyToAsync(fileStream);
        //}
        status = $"Done reading file.";
        stopWatch.Stop();
        status += $" Transfert Duration : {stopWatch.ElapsedMilliseconds} ms";

        comic.Title = comic.Title ?? Path.GetFileNameWithoutExtension(fileInfo.Name);
        comic.EbookPath = "tmp/";
        comic.EbookName = fileInfo.Name;
        this.StateHasChanged();

    }

}
